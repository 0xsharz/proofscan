        data = f.read()

    # Use the pinned-vulnerable source shipped in the image.
    sys.path.insert(0, "/work/src/__SRC_SUBDIR__")
    import __IMPORT__ as lib  # noqa: F401

    # ============================================================
    # THE VULNERABLE SINK — feed `data` (or data.decode()) into the
    # one library call under test. See toolkit/COOKBOOK.md for ready
    # snippets per vuln class. Example (PyYAML deserialization):
    #     import yaml
    #     result = yaml.load(data, Loader=yaml.FullLoader)
    # ============================================================
    with AuditHookOracle():
        try:
            __SINK__
        except Exception:
            return 0  # malformed/rejected input is not a finding

    sys.stdout.write("benign: no exploit primitive reached\n")
    return 0


if __name__ == "__main__":
